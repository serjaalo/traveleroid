# Скопируйте файл в .env и заполните реальными значениями.
# На сервере: cp .env.example .env && nano .env

# Длинный случайный секрет (минимум 32 символа). Сгенерировать: openssl rand -base64 48
NUXT_SESSION_PASSWORD=

# Пароль входа в /admin
ADMIN_PASSWORD=

# В production за HTTPS должно быть true. Для локальной разработки — false или не задавать.
NUXT_SESSION_COOKIE_SECURE=true

# Окружение и порт Node-сервера
NODE_ENV=production
PORT=3000
